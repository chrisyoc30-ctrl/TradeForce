# Copy this file to `.env.local` in the same folder (`web/`) and fill in values.
# Never commit `.env.local` or paste real secrets into chat or public repos.
#
#   copy .env.example .env.local
#
# Then edit `.env.local` in Cursor / VS Code. Next.js loads it automatically in dev.

# --- AI chat (required on Railway for real replies) ---
# Prefer this exact name:
OPENAI_API_KEY=
# Code also accepts OPEN_API_KEY or OPENAI_KEY if you mis-typed the variable in Railway.
OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional: Azure / proxy (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=
# Set to false if your provider errors on response_format (JSON mode)
# OPENAI_JSON_OBJECT_MODE=true

# --- Flask API (set on Railway for lead submission, etc.) ---
# Public URL of your Flask service, no trailing slash
API_URL=
NEXT_PUBLIC_API_URL=
# Lead scoring (Flask only — set on the Railway Flask service, not in Next.js public env)
# ANTHROPIC_API_KEY=

# --- MongoDB (optional; chat history + data) ---
# MONGODB_URI=
# MONGODB_DB_NAME=tradescore

# --- Stripe (optional) ---
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# Hosted Payment Link (test or live); client_reference_id is appended in-app for webhook correlation
NEXT_PUBLIC_STRIPE_PAYMENT_LINK="https://buy.stripe.com/test_cNi6oHfFBeXB4Gra0e4ZG01"

# --- Admin login (optional) ---
# ADMIN_PASSWORD=

# --- URLs / analytics (optional) ---
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
